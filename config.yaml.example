# Example workshop configuration. Copy to config.yaml and customize, or use
# `workshop config init` to materialize one from the current environment.
#
# Providers are defined as a named map under `providers:`. The top-level
# `provider:` field is a string name reference that picks the *default*
# (inference) provider. Other consumers (e.g. compaction) can reference
# their own named entry to use a different model.
#
# Two provider kinds are supported:
#   - "openai" (default) for OpenAI and OpenAI-compatible endpoints
#   - "anthropic" for Anthropic native and OpenRouter's /api/v1/messages
#     mirror (the auth header is auto-selected from base-url)

# The default inference provider; must be a key in the `providers:` map.
provider: sonnet

providers:
  # A cheaper, faster model ideal for background tasks like compaction.
  haiku:
    kind: anthropic
    api-key: sk-ant-...
    model: claude-haiku-3-5
    temperature: 0
    # Default for anthropic: medium; values: off, minimal, low, medium, high, max
    # thinking-level: "medium"
    max-tokens: 0                  # 0 = workshop default of 32000

  # The default inference provider: a larger, more capable model.
  sonnet:
    kind: anthropic
    api-key: sk-ant-...
    model: claude-sonnet-4-5
    temperature: 0
    thinking-level: "medium"
    max-tokens: 0                  # 0 = workshop default of 32000

  # OpenAI-compatible example. To use, set `provider: openai-fast` and
  # supply the env var WORKSHOP_PROVIDER_OPENAI_FAST_API_KEY.
  # openai-fast:
  #   kind: openai
  #   api-key: ""                  # or set WORKSHOP_PROVIDER_OPENAI_FAST_API_KEY
  #   base-url: "https://api.fireworks.ai/inference/v1"
  #   model: accounts/fireworks/models/kimi-k2p6
  #   temperature: 0
  #   thinking-level: "off"         # default for openai-compatible

# Compaction: in ore v0.12 compaction is explicit-only (the /compact
# slash command); there is no automatic pre-turn trigger. Send the
# summarization call to a different (cheaper) model than the inference
# provider by setting `provider:`. Omit `provider:` to reuse the default.
# `max-tokens:` is now the per-invocation output budget forwarded to
# compaction.Summarize via models.Spec.MaxOutputTokens (the framework
# default is 8192). Set `max-tokens: 0` to disable /compact entirely.
compaction:
  provider: haiku
  max-tokens: 8192

log-level: info
pprof: true
store:
  dir: ""
telemetry:
  traces:
    endpoint: "http://localhost:4318"   # OTLP/HTTP endpoint; empty = disabled
  metrics:
    endpoint: "http://localhost:4318"   # OTLP/HTTP endpoint; empty = disabled
